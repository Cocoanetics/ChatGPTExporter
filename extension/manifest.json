{
  "manifest_version": 3,
  "name": "ChatGPT Exporter",
  "version": "1.0",
  "description": "Export the ChatGPT conversation you are viewing as Markdown, with web-search citations as footnotes and optional image/file download.",
  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png",
    "256": "images/icon-256.png",
    "512": "images/icon-512.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Export this chat",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "permissions": [
    "nativeMessaging",
    "scripting",
    "activeTab",
    "clipboardWrite",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ]
}
